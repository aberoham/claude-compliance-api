# Anthropic Compliance & Analytics API (used by Go CLI and Python scripts)
ANTHROPIC_ORG_ID=your-org-uuid
ANTHROPIC_OP_ITEM="Your 1Password Item Name"
COMPLIANCE_OP_FIELD=your-compliance-api-field
ANALYTICS_OP_FIELD=your-analytics-api-field

# Seat management
ANTHROPIC_TOTAL_SEATS=0

# Okta (used by scripts/ and --okta reclaim flag)
OKTA_DOMAIN=your-org.okta.com
OKTA_CLAUDE_GROUP_ID=your-okta-group-id
OKTA_CLAUDE_GROUP_NAME=your-okta-group-name
OKTA_OP_ITEM="Your Okta 1Password Item"
OKTA_OP_FIELD=your-okta-api-token-field
OKTA_CLAUDE_APP_ID=your-okta-claude-app-instance-id
OKTA_CLAUDE_APP_NAME=Anthropic Claude

# Claude session duration (used by --okta reclaim to interpret recent SSO risk)
# Set to 0 (default) for unlimited sessions; >7 enables session-based Okta override
CLAUDE_SESSION_DURATION_DAYS=0
